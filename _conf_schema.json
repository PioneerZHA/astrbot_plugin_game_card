{
  "enable_search_command": {
    "description": "启用 /steam搜索 指令",
    "type": "bool",
    "default": true
  },
  "enable_link_card": {
    "description": "识别 Steam 链接并发送图片图卡",
    "type": "bool",
    "default": true
  },
  "use_llm_translate_for_chinese": {
    "description": "中文搜索时使用当前 AstrBot provider 扩展英文候选词，会消耗模型额度",
    "type": "bool",
    "default": false
  },
  "search_result_count": {
    "description": "搜索结果数量",
    "type": "int",
    "default": 5
  },
  "steam_language": {
    "description": "Steam 商店语言",
    "type": "string",
    "default": "schinese"
  },
  "steam_country": {
    "description": "Steam 商店地区代码",
    "type": "string",
    "default": "cn"
  },
  "render_viewport_width": {
    "description": "图片截图视口宽度",
    "type": "int",
    "default": 1200
  },
  "render_device_scale_factor": {
    "description": "图片截图倍率",
    "type": "int",
    "default": 1
  },
  "browser_executable_path": {
    "description": "可选 Chromium 兼容浏览器可执行文件路径；自动探测系统浏览器目前仅内置 Windows 常见路径",
    "type": "string",
    "default": ""
  },
  "card_template": {
    "description": "内置模板文件名",
    "type": "string",
    "default": "steam_card.html"
  },
  "custom_template_path": {
    "description": "自定义 HTML/Jinja2 模板路径",
    "type": "string",
    "default": ""
  },
  "enable_watermark": {
    "description": "显示图片水印",
    "type": "bool",
    "default": true
  },
  "watermark_text": {
    "description": "水印文案",
    "type": "string",
    "default": "Crafted by pioneerzha"
  }
}
