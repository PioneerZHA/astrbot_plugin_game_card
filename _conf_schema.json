{
  "enable_search_command": {
    "description": "启用 /steam搜索",
    "type": "bool",
    "default": true
  },
  "enable_link_card": {
    "description": "识别链接并发图",
    "type": "bool",
    "default": true
  },
  "use_llm_translate_for_chinese": {
    "description": "中文搜索用 AI 扩展",
    "type": "bool",
    "default": true
  },
  "search_result_count": {
    "description": "搜索结果数量",
    "type": "int",
    "default": 5
  },
  "steam_language": {
    "description": "商店语言",
    "type": "string",
    "default": "schinese"
  },
  "steam_country": {
    "description": "商店地区",
    "type": "string",
